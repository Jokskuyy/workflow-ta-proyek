        "columns": ["id", "nama_fakultas", "deskripsi_fakultas", "email", "website", "id_gedung_utama"]
      },
      {
        "name": "program_studi",
        "columns": ["id", "nama_prodi", "jenjang", "id_fakultas", "akreditasi"]
      },
      {
        "name": "admin_users",
        "columns": ["id", "username", "password_hash", "nama_lengkap", "role", "created_at"]
      },
      {
        "name": "audit_logs",
        "columns": ["id", "actor_id", "actor_email", "action", "table_name", "record_id", "old_data", "new_data", "created_at"]
